<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Baumann Consulting – SAP Field Service Management & Extension Development</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --navy: #0d1b2a;
      --blue: #1a4f8a;
      --accent: #2e86de;
      --light: #f4f7fc;
      --white: #ffffff;
      --text: #2d2d2d;
      --muted: #6b7280;
    }

    body {
      font-family: 'Segoe UI', Arial, sans-serif;
      color: var(--text);
      background: var(--white);
      line-height: 1.65;
    }

    /* ── NAV ── */
    nav {
      position: sticky;
      top: 0;
      z-index: 100;
      background: var(--navy);
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0 2.5rem;
      height: 64px;
    }

    .nav-logo {
      color: var(--white);
      font-size: 1.15rem;
      font-weight: 700;
      letter-spacing: 0.03em;
    }

    .nav-logo span { color: var(--accent); }

    nav ul {
      list-style: none;
      display: flex;
      gap: 2rem;
    }

    nav ul li a {
      color: #cbd5e1;
      text-decoration: none;
      font-size: 0.9rem;
      transition: color 0.2s;
    }

    nav ul li a:hover { color: var(--accent); }

    /* ── HERO ── */
    #hero {
      background: linear-gradient(135deg, var(--navy) 0%, var(--blue) 100%);
      color: var(--white);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 7rem 2rem 5rem;
      gap: 1.5rem;
    }

    .hero-photo {
      width: 150px;
      height: 150px;
      border-radius: 50%;
      object-fit: cover;
      border: 4px solid var(--accent);
      /* REPLACE src with your own photo */
      background: #2a4a70;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.75rem;
      color: #94a3b8;
      overflow: hidden;
    }

    .hero-photo img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    #hero h1 {
      font-size: clamp(2rem, 5vw, 3.2rem);
      font-weight: 800;
      letter-spacing: -0.02em;
    }

    #hero h1 span { color: var(--accent); }

    #hero p.tagline {
      font-size: 1.15rem;
      color: #bfdbfe;
      max-width: 560px;
    }

    .sap-id {
      font-size: 0.8rem;
      color: #64748b;
      letter-spacing: 0.05em;
    }

    .btn {
      display: inline-block;
      background: var(--accent);
      color: var(--white);
      padding: 0.75rem 2rem;
      border-radius: 6px;
      text-decoration: none;
      font-weight: 600;
      font-size: 0.95rem;
      transition: background 0.2s, transform 0.15s;
    }

    .btn:hover { background: #1a72c4; transform: translateY(-1px); }

    /* ── SECTIONS ── */
    section { padding: 5rem 2rem; }
    section:nth-of-type(even) { background: var(--light); }

    .container {
      max-width: 1000px;
      margin: 0 auto;
    }

    .section-label {
      text-transform: uppercase;
      letter-spacing: 0.12em;
      font-size: 0.75rem;
      color: var(--accent);
      font-weight: 700;
      margin-bottom: 0.5rem;
    }

    h2 {
      font-size: clamp(1.6rem, 3vw, 2.2rem);
      font-weight: 800;
      color: var(--navy);
      margin-bottom: 1.25rem;
    }

    /* ── ABOUT ── */
    .about-grid {
      display: grid;
      grid-template-columns: 220px 1fr;
      gap: 3rem;
      align-items: start;
    }

    .about-photo-wrap {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.75rem;
    }

    .about-photo {
      width: 200px;
      height: 240px;
      border-radius: 10px;
      object-fit: cover;
      border: 3px solid var(--accent);
      background: #dbeafe;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.75rem;
      color: var(--muted);
      text-align: center;
      overflow: hidden;
    }

    .about-photo img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .about-photo-caption {
      font-size: 0.82rem;
      color: var(--muted);
      text-align: center;
    }

    .about-text p { color: #444; margin-bottom: 1rem; }

    .badge {
      display: inline-block;
      background: #dbeafe;
      color: var(--blue);
      font-size: 0.78rem;
      font-weight: 600;
      padding: 0.25rem 0.7rem;
      border-radius: 99px;
      margin: 0.2rem 0.15rem;
    }

    /* ── SERVICES ── */
    .services-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 1.5rem;
      margin-top: 2rem;
    }

    .card {
      background: var(--white);
      border-radius: 10px;
      padding: 1.75rem;
      box-shadow: 0 2px 12px rgba(0,0,0,0.07);
      border-top: 4px solid var(--accent);
      transition: transform 0.2s, box-shadow 0.2s;
    }

    .card:hover { transform: translateY(-4px); box-shadow: 0 8px 24px rgba(0,0,0,0.1); }

    .card-icon {
      font-size: 2rem;
      margin-bottom: 0.75rem;
    }

    .card h3 {
      font-size: 1.05rem;
      font-weight: 700;
      color: var(--navy);
      margin-bottom: 0.5rem;
    }

    .card p { font-size: 0.9rem; color: var(--muted); }

    /* ── WHY ── */
    .why-list {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 1.25rem;
      margin-top: 2rem;
    }

    .why-item {
      display: flex;
      gap: 0.75rem;
      align-items: flex-start;
    }

    .why-icon {
      flex-shrink: 0;
      width: 2.2rem;
      height: 2.2rem;
      border-radius: 50%;
      background: var(--accent);
      color: var(--white);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1rem;
    }

    .why-item h4 { font-size: 0.92rem; font-weight: 700; color: var(--navy); }
    .why-item p { font-size: 0.85rem; color: var(--muted); margin-top: 0.2rem; }

    /* ── CONTACT ── */
    #contact { background: var(--navy); color: var(--white); text-align: center; }
    #contact h2 { color: var(--white); }
    #contact p { color: #94a3b8; margin-bottom: 1.5rem; }

    .contact-links {
      display: flex;
      justify-content: center;
      gap: 1.25rem;
      flex-wrap: wrap;
      margin-top: 1.5rem;
    }

    .contact-links a {
      color: var(--accent);
      text-decoration: none;
      font-weight: 600;
      font-size: 0.9rem;
      border: 1px solid var(--accent);
      padding: 0.5rem 1.25rem;
      border-radius: 6px;
      transition: background 0.2s, color 0.2s;
    }

    .contact-links a:hover { background: var(--accent); color: var(--white); }

    /* ── FOOTER ── */
    footer {
      background: #070e18;
      color: #475569;
      text-align: center;
      padding: 1.25rem;
      font-size: 0.8rem;
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 640px) {
      .about-grid { grid-template-columns: 1fr; }
      .about-photo-wrap { margin: 0 auto; }
      nav ul { gap: 1rem; }
    }
  </style>
</head>
